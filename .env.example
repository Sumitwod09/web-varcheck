# --- Ollama (chat widget) ---
# Base URL of your Ollama server. Default is local Ollama.
# Local dev:  http://localhost:11434
# Production: a PUBLICLY reachable URL (the deployed site cannot reach your localhost).
#             e.g. a tunnel (ngrok/cloudflared) or a hosted Ollama endpoint.
OLLAMA_BASE_URL=http://localhost:11434

# Model to use. Must be pulled on the Ollama server:  ollama pull qwen2.5-coder:3b
OLLAMA_MODEL=qwen2.5-coder:3b
